    {
      "id": 31,
      "title": "Rolling MAE \u2014 7d vs 28d (kWh)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 25
      },
      "datasource": {
        "type": "postgres",
        "uid": "sparc-postgres"
      },
      "options": {
        "legend": {
          "calcs": [
            "last"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwh",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "mae_7d"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "mae_28d"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "sparc-postgres"
          },
          "rawSql": "SELECT checked_at AS time, model_mae_7d AS mae_7d, model_mae_28d AS mae_28d FROM model_drift_log WHERE household_id = (SELECT id FROM households ORDER BY onboarded_at DESC LIMIT 1) ORDER BY checked_at",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "title": "Drift Ratio (7d/28d) \u2014 Alert if > 1.25",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 25
      },
      "datasource": {
        "type": "postgres",
        "uid": "sparc-postgres"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1.1
              },
              {
                "color": "red",
                "value": 1.25
              }
            ]
          },
          "min": 0,
          "max": 2
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "sparc-postgres"
          },
          "rawSql": "SELECT checked_at AS time, COALESCE(drift_ratio, 1.0) AS drift_ratio FROM model_drift_log WHERE household_id = (SELECT id FROM households ORDER BY onboarded_at DESC LIMIT 1) ORDER BY checked_at DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "title": "Drift Alerts",
      "type": "table",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 25
      },
      "datasource": {
        "type": "postgres",
        "uid": "sparc-postgres"
      },
      "options": {
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "sparc-postgres"
          },
          "rawSql": "SELECT checked_at, ROUND(model_mae_7d,4) AS mae_7d, ROUND(drift_ratio,3) AS ratio, alert_sent, notes FROM model_drift_log WHERE household_id = (SELECT id FROM households ORDER BY onboarded_at DESC LIMIT 1) ORDER BY checked_at DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    }
