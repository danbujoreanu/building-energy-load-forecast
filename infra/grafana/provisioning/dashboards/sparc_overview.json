    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 21,
      "title": "Energy Consumption",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "sparc-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "kWh",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 3,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "kwatth",
          "decimals": 3
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "30-Minute Meter Readings — Import & Export",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "sparc-postgres" },
          "rawSql": "SELECT\n  recorded_at AS \"time\",\n  import_kwh AS \"Import (kWh)\"\nFROM meter_readings\nWHERE $__timeFilter(recorded_at)\nORDER BY recorded_at",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": { "type": "postgres", "uid": "sparc-postgres" },
          "rawSql": "SELECT\n  recorded_at AS \"time\",\n  export_kwh AS \"Export (kWh)\"\nFROM meter_readings\nWHERE $__timeFilter(recorded_at)\nORDER BY recorded_at",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 22,
      "title": "Forecasts & Control",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "sparc-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "kWh/hour",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "kwatth",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 16 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "Latest H+24 Forecast — P10 / P50 / P90",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "sparc-postgres" },
          "rawSql": "SELECT\n  (forecast_date + (generate_series(0,23) * interval '1 hour')) AS \"time\",\n  (p50_kwh[generate_series(1,24)]) AS \"P50\",\n  (p10_kwh[generate_series(1,24)]) AS \"P10\",\n  (p90_kwh[generate_series(1,24)]) AS \"P90\"\nFROM predictions\nORDER BY issued_at DESC\nLIMIT 24",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "sparc-postgres" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "title": "Recent Control Recommendations",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "sparc-postgres" },
          "rawSql": "SELECT\n  issued_at::date AS \"Date\",\n  hour_of_day AS \"Hour\",\n  action AS \"Action\",\n  ROUND(confidence::numeric, 2) AS \"Confidence\",\n  ROUND(estimated_saving_eur::numeric, 4) AS \"Saving €\"\nFROM recommendations\nORDER BY issued_at DESC\nLIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
