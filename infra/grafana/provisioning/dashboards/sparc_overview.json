            "uid": "sparc-postgres"
          },
          "rawSql": "SELECT\n  issued_at::date AS \"Date\",\n  hour_of_day AS \"Hour\",\n  action AS \"Action\",\n  ROUND(confidence::numeric, 2) AS \"Confidence\",\n  ROUND(estimated_saving_eur::numeric, 4) AS \"Saving \u20ac\"\nFROM recommendations\nORDER BY issued_at DESC\nLIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
