# Data — never bake raw data into the image (use S3 or mounted volume)
data/
outputs/predictions/
outputs/figures/
outputs/results/

# Exclude RandomForest model files — research artefacts, ~400MB each, never used in production
# LightGBM/XGBoost/Ridge models (~5MB each) are retained for inference
outputs/models/*RandomForest*
outputs/models/*random_forest*

# Dev artefacts
notebooks/
checkpoints/
lightning_logs/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# Git / IDE
.git/
.gitignore
.github/
.vscode/
.idea/

# Documentation (not needed at runtime)
docs/
*.md

# Large ML frameworks — not needed in inference container
# (TensorFlow, PyTorch, pytorch-forecasting are in root requirements.txt
#  but NOT in deployment/requirements.txt — they are correctly excluded)
