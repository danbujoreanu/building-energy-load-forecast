# ─────────────────────────────────────────────────────────────────────────────
# Sparc Energy — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password

# ── myenergi Eddi ─────────────────────────────────────────────────────────────
# Get from: myenergi.com → App → Hub → API key
MYENERGI_HUB_SERIAL=your_hub_serial_here
MYENERGI_API_KEY=your_api_key_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── API ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Forecast model ────────────────────────────────────────────────────────────
DEFAULT_CITY=ireland
FORECAST_HORIZON=24

# ── LLM Advisor (P-13) — Gemini Flash recommended (user has Gemini Pro) ──────
# GEMINI_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-2.0-flash

# ── SEMO / ENTSO-E Day-Ahead Market prices (D-20, Phase B) ───────────────────
# ENTSO_E_TOKEN=your_token_here

# ── Cloudflare Tunnel (optional — for public HTTPS from Mac Mini) ─────────────
# CLOUDFLARE_TUNNEL_TOKEN=your_token_here

# ── AWS (Phase 3 production) ─────────────────────────────────────────────────
# AWS_ACCOUNT_ID=123456789012
# AWS_DEFAULT_REGION=eu-west-1
